NODE_ENV=development
PORT=4000
TRUST_PROXY=0

DATABASE_URL="postgresql://postgres:password@localhost:5432/youniverse_db?schema=public"

JWT_SECRET="change_this_secret"
JWT_EXPIRES_IN="1d"
GOOGLE_CLIENT_ID=""

FRONTEND_URL="http://localhost:3000"
