EMAIL_FROM_NAME="YOUniverse"
EMAIL_FROM_ADDRESS="no-reply@youniverse.local"
EMAIL_SMTP_HOST=""
EMAIL_SMTP_PORT="587"
EMAIL_SMTP_USER=""
