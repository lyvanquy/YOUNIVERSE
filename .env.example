COMPOSE_PROJECT_NAME=youniverse

POSTGRES_USER=youniverse
POSTGRES_PASSWORD=replace_with_a_long_database_password
POSTGRES_DB=youniverse
DATABASE_URL=postgresql://youniverse:replace_with_a_long_database_password@db:5432/youniverse?schema=public

JWT_SECRET=replace_with_at_least_32_random_characters
JWT_EXPIRES_IN=1d

FRONTEND_URL=https://youniverse.io.vn
ADMIN_URL=https://admin.youniverse.io.vn
BACKEND_URL=https://api.youniverse.io.vn
NEXT_PUBLIC_API_URL=https://api.youniverse.io.vn/api/v1

GOOGLE_CLIENT_ID=
GOOGLE_MAPS_API_KEY=

EMAIL_FROM_NAME=YOUniverse
EMAIL_FROM_ADDRESS=no-reply@youniverse.io.vn
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=

FRONTEND_PORT=3000
BACKEND_PORT=4000
ADMIN_PORT=8080
