// YOUniverse Phase 1 Prisma Schema
// Copy this file to: prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PageType {
  HOME
  OUR_UNIVERSE
  ABOUT
}

enum SocialPlatform {
  TIKTOK
  INSTAGRAM
  FACEBOOK
  OTHER
}

model ProductLine {
  id          String   @id @default(uuid())
  slug        String   @unique
  name        String
  badge       String
  shortIntro  String?
  tagline     String
  description String?
  imageUrl    String?
  ctaLabel    String   @default("Coming soon")
  ctaHref     String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
  @@index([sortOrder])
}

model SocialLink {
  id        String         @id @default(uuid())
  platform  SocialPlatform @default(OTHER)
  label     String
  url       String
  sortOrder Int            @default(0)
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([isActive])
  @@index([sortOrder])
}

model ContactPerson {
  id        String   @id @default(uuid())
  name      String
  phone     String
  role      String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([sortOrder])
}

model SiteSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PageContent {
  id         String   @id @default(uuid())
  page       PageType
  sectionKey String
  title      String?
  subtitle   String?
  body       String?
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([page, sectionKey])
  @@index([page])
  @@index([isActive])
  @@index([sortOrder])
}

model LeadSubmission {
  id        String   @id @default(uuid())
  name      String?
  email     String?
  phone     String?
  message   String?
  source    String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}
